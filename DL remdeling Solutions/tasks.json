{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start-extension-live-server",
            "type": "shell",
            "command": "code",
            "args": [
                "--command",
                "extension.liveServer.goOnline"
            ],
            "problemMatcher": []
        }
        ,
        {
            "label": "Build Current File (gcc)",
            "type": "shell",
            "command": "C:\\MinGW\\bin\\gcc.exe",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}
